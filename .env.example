# Optional environment overrides for Voice Chat Local.
# Copy to `.env` to override values from config.yaml.
# Uppercase, double-underscore-nested keys map onto the config groups.

# Server
# VCL_SERVER__HOST=0.0.0.0
# VCL_SERVER__PORT=8000

# Model/asset paths (useful if models live outside the project)
# VCL_PATHS__LLM_PATH=./models/llm/Qwen_Qwen3-4B-Instruct-2507-Q4_K_M.gguf
# VCL_PATHS__WHISPER_DIR=./models/whisper

# STT
# VCL_STT__DEVICE=cuda
# VCL_STT__LANGUAGE=pt

# TTS
# VCL_TTS__ENGINE=piper
# VCL_TTS__VOICE=pt_BR-faber-medium

# Path to the config file itself (defaults to ./config.yaml)
# VCL_CONFIG_FILE=./config.yaml
